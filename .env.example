# ================================================================
#  Expense Tracker — environment variable template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ================================================================

# MySQL root password — used by all Spring Boot services
MYSQL_ROOT_PASSWORD=change_me

# JWT signing secret — must be a Base64-encoded HMAC-SHA256 key (min 256 bits)
# Generate with: openssl rand -hex 32 | xxd -p | tr -d '\n'
JWT_SECRET=change_me

# Mistral AI API key — used by ds-service for Smart Import
MISTRAL_API_KEY=change_me
