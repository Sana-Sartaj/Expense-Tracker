# ============================================================
# Expense Tracker — Docker Compose environment variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------ MySQL -----------------------------------------------
# Root password for the MySQL container.
MYSQL_ROOT_PASSWORD=change-me

# Credentials that authservice, userservice, and expenseservice
# use to connect to MySQL. Connect as root unless a dedicated
# application user has been provisioned in MySQL.
MYSQL_USER=change-me
MYSQL_PASSWORD=change-me

# ------ dsService (LLM API) ---------------------------------
# Mistral AI API key used by dsService to call ChatMistralAI.
MISTRAL_API_KEY=change-me
